  "query": "\n            SELECT \n                b.id,\n                b.external_id AS bangumi_id,\n                b.title,\n                b.type,\n                d.author,\n                d.release_date,\n                d.episodes,\n                d.description,\n                b.cover_url,\n                d.updated_at AS \"updated_at?\"\n            FROM bangumi_info_easy b\n            LEFT JOIN bangumi_info_detailed d\n                ON d.bangumi_id = b.id\n            WHERE b.id = ?\n            ",
