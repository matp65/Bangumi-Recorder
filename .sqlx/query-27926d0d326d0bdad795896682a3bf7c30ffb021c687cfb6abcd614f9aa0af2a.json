  "query": "\n        SELECT \n            r.id,\n            r.bangumi_id AS local_bangumi_id,\n            b.external_id AS bangumi_id,\n            r.recorder,\n            r.status,\n            r.is_delete,\n            r.updated_at\n        FROM recordings r\n        LEFT JOIN bangumi_info_easy b\n            ON r.bangumi_id = b.id\n        WHERE r.user_id = ? AND r.bangumi_id IS NOT NULL\n        ",
