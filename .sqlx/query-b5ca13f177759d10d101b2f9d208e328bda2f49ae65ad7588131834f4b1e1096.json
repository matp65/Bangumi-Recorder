{
  "db_name": "MySQL",
  "query": "\n        SELECT \n            r.id,\n            r.bangumi_id AS local_bangumi_id,\n            r.external_media_id AS local_external_media_id,\n            r.other_id,\n            o.name AS title,\n            o.cover_url,\n            o.max_number AS episodes,\n            r.recorder,\n            r.status,\n            r.is_delete,\n            r.updated_at,\n            r.created_at\n        FROM recordings r\n        LEFT JOIN other_recorders o ON r.other_id = o.id\n        WHERE r.user_id = ? AND r.other_id IS NOT NULL\n        ",
