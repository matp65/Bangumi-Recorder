  "query": "\n        SELECT\n            m.external_id,\n            m.title,\n            m.cover_url,\n            m.type AS \"type!: i8\",\n            d.author,\n            d.release_date,\n            d.episodes,\n            d.description,\n            d.updated_at AS \"updated_at?\"\n        FROM external_media m\n        LEFT JOIN external_media_detailed d ON d.media_id = m.id\n        WHERE m.source = ? AND m.external_id = ?\n        ",
