  "query": "\n        SELECT \n            r.id,\n            r.external_media_id AS local_external_media_id,\n            e.source,\n            e.external_id,\n            r.recorder,\n            r.status,\n            r.is_delete,\n            r.updated_at\n        FROM recordings r\n        LEFT JOIN external_media e ON r.external_media_id = e.id\n        WHERE r.user_id = ? AND r.external_media_id IS NOT NULL\n        ",
